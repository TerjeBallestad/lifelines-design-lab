{
  "name": "Lifelines Design Lab Harness",
  "contractNegotiation": {
    "enabled": true,
    "maxRounds": 2
  },
  "maxAttempts": 2,
  "worktree": {
    "enabled": true,
    "setup": "npm ci"
  },
  "sdd": {
    "resolver": "tools/harness/resolve-sdd.sh"
  },
  "prompts": {
    "plannerPacket": "tools/harness/prompts/planner-packet.md"
  },
  "reporting": {
    "slack": {
      "enabled": true,
      "channel": "C0B4FSC37SS",
      "tokenEnv": "SLACK_BOT_TOKEN"
