    "planner": { "agent": "codex", "sandbox": "read-only", "timeoutSec": 1200 },
    "generator": { "agent": "codex", "timeoutSec": 3600 },
    "evaluator": { "agent": "codex", "sandbox": "read-only", "timeoutSec": 1800 }
  },
  "verifiers": [
    {
      "id": "web-ui-smoke",
      "command": "tools/harness/web-ui-smoke.sh",
      "evidence": "interactive-ui"
    }
  ]
